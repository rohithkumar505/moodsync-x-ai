# Backend
SECRET_KEY=dev-secret-change-in-production
JWT_SECRET_KEY=jwt-secret-change-in-production
FLASK_ENV=development
OPENAI_API_KEY=
UPLOAD_MAX_SIZE_MB=5
PORT=5001

# PostgreSQL (default — used when DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=moodsync
POSTGRES_PASSWORD=moodsync
POSTGRES_DB=moodsync

# Or set a full connection string (overrides POSTGRES_* above)
# DATABASE_URL=postgresql://moodsync:moodsync@localhost:5432/moodsync

# Frontend (frontend/.env)
VITE_API_URL=

# Production — set in Vercel dashboard (Render backend URL, no trailing slash)
# VITE_API_URL=https://moodsync-api.onrender.com

# Render backend — comma-separated Vercel URLs after frontend deploy
# CORS_ORIGINS=https://your-app.vercel.app
